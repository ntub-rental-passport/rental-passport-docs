        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml RentMate_Package_Diagram_7_2\n\ntitle &lt;size:16&gt;&lt;b&gt;圖 7-2　RentMate 套件圖&lt;/b&gt;&lt;/size&gt;\n\nleft to right direction\n\nskinparam defaultFontName  \&quot;Noto Sans TC\&quot;\nskinparam defaultFontSize  11\nskinparam backgroundColor  #FFFFFF\nskinparam shadowing        false\nskinparam packageStyle     folder\nskinparam padding          8\nskinparam nodesep          40\nskinparam ranksep          60\n\nskinparam package {\n    BackgroundColor  #F5F5F5\n    BorderColor      #000000\n    BorderThickness  1.5\n    FontSize         11\n    FontColor        #000000\n    FontStyle        bold\n}\n\nskinparam ArrowColor     #000000\nskinparam ArrowFontSize  9\nskinparam ArrowFontColor #000000\nskinparam ArrowThickness 1.2\nskinparam linetype       ortho\n\n&#39; ── Frontend ──\npackage \&quot;Frontend Package\&quot; as Frontend {\n    package \&quot;views/\&quot;      as views\n    package \&quot;components/\&quot; as components\n    package \&quot;stores/\&quot;     as stores\n    package \&quot;router/\&quot;     as router\n    package \&quot;services/\&quot;   as fe_svc\n}\n\n&#39; ── Backend ──\npackage \&quot;Backend Package\&quot; as Backend {\n    package \&quot;api/\&quot;      as api\n    package \&quot;services/\&quot; as be_svc\n    package \&quot;models/\&quot;   as models\n    package \&quot;schemas/\&quot;  as schemas\n    package \&quot;core/\&quot;     as core\n}\n\n&#39; ── Database ──\npackage \&quot;Database Package\&quot; as Database {\n    package \&quot;MySQL\\n(關聯式資料庫)\&quot;  as mysql\n    package \&quot;ChromaDB\\n(向量資料庫)\&quot; as chroma\n}\n\n&#39; ── External ──\npackage \&quot;External Package\&quot; as External {\n    package \&quot;Google Cloud Vision\&quot;  as vision\n    package \&quot;Anthropic Claude API\&quot; as claude\n    package \&quot;Google OAuth API\&quot;     as oauth\n    package \&quot;Web Push Service\&quot;     as webpush\n    package \&quot;政府開放資料\&quot;          as govdata\n\n\n}\n\n&#39; ── 關係 ──\nviews   ..&gt; stores     : «access»\nviews   ..&gt; router     : «import»\nviews   ..&gt; components : «access»\n\napi     ..&gt; be_svc  : «import»\nbe_svc  ..&gt; models  : «access»\nbe_svc  ..&gt; schemas : «access»\nbe_svc  ..&gt; core    : «access»\n\nfe_svc  ..&gt; api : HTTP / REST\n\nmodels  ..&gt; mysql  : «access»\nbe_svc  ..&gt; chroma : «access»\n\nbe_svc  ..&gt; vision  : «access»\nbe_svc  ..&gt; claude  : «access»\nbe_svc  ..&gt; oauth   : «access»\nbe_svc  ..&gt; webpush : «access»\nbe_svc  ..&gt; govdata : «access»\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="0LR7DCreIEitUdqZfCCi-1">
